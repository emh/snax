{
  "name": "snax",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "wds --root-dir app --watch --app-index index.html --hostname 127.0.0.1 --port 8032",
    "dev:worker:sync": "WRANGLER_LOG_PATH=.wrangler/logs wrangler dev --cwd workers/sync --config wrangler.toml --ip 0.0.0.0 --port 8797 --inspector-ip 127.0.0.1 --inspector-port 9247 --persist-to ../../.wrangler/state/sync",
    "deploy:worker:sync": "wrangler deploy --config workers/sync/wrangler.toml",
    "check": "node --check app/model.js && node --check app/storage.js && node --check app/sync.js && node --check app/main.js && node --check workers/sync/src/index.js"
  },
  "devDependencies": {
    "@web/dev-server": "^0.4.6",
    "wrangler": "^4.84.0"
  }
}
